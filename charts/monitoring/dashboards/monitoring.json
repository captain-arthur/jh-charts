      "id": 100,
      "panels": [],
      "title": "요약",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Prometheus가 스크래핑하는 모든 타겟의 상태. 1 = 정상 수집, 0 = 실패 또는 미수집. job별로 타겟 수를 보여줍니다. 값이 0이면 해당 job의 엔드포인트에 연결할 수 없음을 의미합니다.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(up == 1) by (job)", "legendFormat": "{{job}}", "refId": "A" }],
      "title": "스크래핑 성공 타겟 수 (job별)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "현재 클러스터에 존재하는 노드(호스트) 수. kube_node_info는 각 노드당 1개의 시계열을 가지므로 count()가 노드 개수입니다. 테스트 클러스터 규모를 한눈에 파악할 수 있습니다.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(kube_node_info)", "legendFormat": "노드 수", "refId": "A" }],
      "title": "노드 수",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "현재 Running 상태인 Pod 수. kube_pod_status_phase에서 phase=Running인 Pod만 집계합니다. 워크로드가 정상 기동 중인지 빠르게 확인할 수 있습니다.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(kube_pod_status_phase{phase=\"Running\"})", "legendFormat": "Running Pod", "refId": "A" }],
      "title": "Running Pod 수",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "클러스터 내 네임스페이스 개수. kube_namespace_created 메트릭의 고유 네임스페이스 수로 집계합니다. 리소스 격리 단위 수를 보여줍니다.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(kube_namespace_created)", "legendFormat": "네임스페이스", "refId": "A" }],
      "title": "네임스페이스 수",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Prometheus가 수집 중인 시계열 수. prometheus_tsdb_head_series는 TSDB 헤드에 로드된 고유 시계열 개수입니다. 수가 비정상적으로 많으면 수집 대상 또는 레이블 조합을 점검해야 합니다.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "prometheus_tsdb_head_series", "legendFormat": "시계열 수", "refId": "A" }],
      "title": "Prometheus 시계열 수",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "각 타겟별 스크래핑 성공 여부. up 메트릭은 스크래핑 시도 결과(1=성공, 0=실패)를 나타냅니다. instance 레이블로 어떤 타겟이 실패했는지 확인할 수 있습니다.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [{ "options": { "0": "실패" }, "type": "value" }, { "options": { "1": "정상" }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "up", "legendFormat": "{{job}} / {{instance}}", "refId": "A" }],
      "title": "타겟별 up 상태",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": [],
      "title": "Prometheus",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "각 스크래핑 작업이 한 번의 스크래핑에 걸린 시간(초). job·instance별로 표시됩니다. 값이 크면 타겟 응답 지연 또는 네트워크 지연을 의심할 수 있습니다.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "auto", "spanNulls": false, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" }, "unit": "s" }, "overrides": [] },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "scrape_duration_seconds", "legendFormat": "{{job}} {{instance}}", "refId": "A" }],
      "title": "스크래핑 소요 시간",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Prometheus TSDB가 디스크에 저장한 블록 데이터의 총 바이트 수. 시계열 데이터가 얼마나 쌓였는지 보여주며, 디스크 사용량 계획에 참고할 수 있습니다.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "auto", "spanNulls": false, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" }, "unit": "bytes" }, "overrides": [] },
        "overrides": []
