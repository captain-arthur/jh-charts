      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "prometheus_tsdb_storage_blocks_bytes", "legendFormat": "TSDB 블록", "refId": "A" }],
      "title": "TSDB 스토리지 블록 크기",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
